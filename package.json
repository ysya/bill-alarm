      "esbuild",
      "prisma",
      "protobufjs",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "release-it": "^19.2.4",
    "turbo": "^2.9.0"
  },
  "version": "0.0.8"
}
