{
  "name": "bill-alarm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "dev:server": "turbo dev --filter=@bill-alarm/server",
    "dev:web": "turbo dev --filter=@bill-alarm/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "release": "release-it"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
