generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BankAccount {
  id        String   @id @default(uuid(7))
  name      String
  bankName  String
  note      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  banks     Bank[]

  @@map("bank_accounts")
}

model Bank {
  id                  String       @id @default(uuid(7))
  code                String?
  name                String
  emailSenderPattern  String
  emailSubjectPattern String
  pdfPassword         String?
  parserConfig        String?
  isBuiltin           Boolean      @default(false)
  isActive            Boolean      @default(true)
  autoDebit           Boolean      @default(false)
  bankAccountId       String?
  bankAccount         BankAccount? @relation(fields: [bankAccountId], references: [id])
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  bills               Bill[]

  @@unique([userId, code])
  @@map("banks")
}

model Bill {
  id               String            @id @default(uuid(7))
  bankId           String
  bank             Bank              @relation(fields: [bankId], references: [id], onDelete: Cascade)
  billingPeriod    String
  amount           Int
  minimumPayment   Int?
  dueDate          String            // calendar date, 'YYYY-MM-DD'
  status           String            @default("pending")
  parseSource      String?           // 'template' | 'hardcoded' | 'llm' ('generic' exists on legacy rows)
  paidAt           DateTime?
  sourceEmailId    String?
  rawEmailSnippet  String?
  pdfPath          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  notifications    NotificationLog[]

  @@unique([bankId, billingPeriod])
  @@index([status, dueDate])
  @@index([bankId])
  @@map("bills")
}

model NotificationRule {
  id         String            @id @default(uuid(7))
  name       String
  daysBefore Int
  timeOfDay  String
  channels   String
  isActive   Boolean           @default(true)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  logs       NotificationLog[]

  @@map("notification_rules")
}

model NotificationLog {
  id           String            @id @default(uuid(7))
  billId       String
  bill         Bill              @relation(fields: [billId], references: [id], onDelete: Cascade)
  ruleId       String?
  rule         NotificationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  channel      String
  message      String
  success      Boolean
  errorMessage String?
  sentAt       DateTime          @default(now())

  @@map("notification_logs")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model ScanLog {
  id            String    @id @default(uuid(7))
  trigger       String    // 'manual' | 'cron'
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  scanned       Int       @default(0)
  newBillsCount Int       @default(0)
  errorCount    Int       @default(0)
  // JSON-stringified array of { stage, bank?, msgId?, reason }
  errors        String?
  fatalError    String?

  @@index([startedAt])
  @@map("scan_logs")
}

model User {
  id                String             @id @default(uuid(7))
  username          String             @unique
  passwordHash      String
  role              String             @default("member") // 'admin' | 'member'
  telegramChatId    String?
  imapHost          String?
  imapPort          Int?
  imapUser          String?
  imapPassword      String?
  icsFeedToken      String?            @unique
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  sessions          Session[]
  banks             Bank[]
  bankAccounts      BankAccount[]
  notificationRules NotificationRule[]
  scanLogs          ScanLog[]

  @@map("users")
}

model Session {
  id             String   @id @default(uuid(7))
  tokenHash      String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  lastExtendedAt DateTime @default(now())

  @@index([expiresAt])
  @@map("sessions")
}
